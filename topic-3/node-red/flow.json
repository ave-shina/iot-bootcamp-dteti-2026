  {"id": "n_text_status", "type": "ui_text", "name": "Status Pintu", "group": "ui_grp_pintu", "order": 1, "width": 0, "height": 0, "label": "Status", "format": "{{msg.payload}}", "layout": "row-spread", "className": "", "style": false, "font": "", "fontSize": 16, "color": "#000000", "x": 620, "y": 360, "z": "main_flow", "wires": []},


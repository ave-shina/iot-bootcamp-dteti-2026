  {"id": "n_kontrol_http", "type": "http request", "name": "GET /kontrol/pintu.json", "method": "GET", "ret": "txt", "paytoqs": "ignore", "url": "https://bootcamp-iot-dteti-2026-ave-default-rtdb.firebaseio.com/kontrol/pintu.json", "tls": "", "persist": false, "proxy": "", "insecureHTTPParser": false, "authType": "", "senderr": false, "headers": [], "x": 370, "y": 420, "z": "main_flow", "wires": [["n_text_kontrol"]]},
  {"id": "n_text_kontrol", "type": "ui_text", "name": "Kontrol Value", "group": "ui_grp_pintu", "order": 2, "width": 0, "height": 0, "label": "Kontrol", "format": "{{msg.payload}}", "layout": "row-spread", "className": "", "style": false, "font": "", "fontSize": 16, "color": "#000000", "x": 620, "y": 420, "z": "main_flow", "wires": []},

  {"id": "n_btn_unlock", "type": "ui_button", "name": "Button UNLOCK", "group": "ui_grp_pintu", "order": 3, "width": "3", "height": "1", "passthru": false, "label": "UNLOCK", "tooltip": "Buka pintu via Firebase", "color": "#ffffff", "bgcolor": "#CA3838", "className": "", "icon": "lock-open", "payload": "\"UNLOCK\"", "payloadType": "str", "topic": "topic.unlock", "x": 130, "y": 520, "z": "main_flow", "wires": [["n_put_unlock"]]},
  {"id": "n_put_unlock", "type": "http request", "name": "PUT /kontrol/pintu = UNLOCK", "method": "PUT", "ret": "txt", "paytoqs": "ignore", "url": "https://bootcamp-iot-dteti-2026-ave-default-rtdb.firebaseio.com/kontrol/pintu.json", "tls": "", "persist": false, "proxy": "", "insecureHTTPParser": false, "authType": "", "senderr": false, "headers": [{"keyType": "Content-Type", "keyValue": "Content-Type", "valueType": "other", "valueValue": "application/json"}], "x": 410, "y": 520, "z": "main_flow", "wires": [["n_unlock_toast", "n_unlock_debug"]]},

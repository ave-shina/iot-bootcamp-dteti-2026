  {"id": "n_unlock_debug", "type": "debug", "name": "Debug UNLOCK", "active": true, "tosidebar": true, "console": false, "tostatus": false, "complete": "true", "targetType": "full", "statusVal": "", "statusType": "auto", "x": 700, "y": 540, "z": "main_flow", "wires": []},

  {"id": "n_btn_lock", "type": "ui_button", "name": "Button LOCK", "group": "ui_grp_pintu", "order": 4, "width": "3", "height": "1", "passthru": false, "label": "LOCK", "tooltip": "Kunci pintu via Firebase", "color": "#ffffff", "bgcolor": "#333333", "className": "", "icon": "lock", "payload": "\"LOCK\"", "payloadType": "str", "topic": "topic.lock", "x": 130, "y": 580, "z": "main_flow", "wires": [["n_put_lock"]]},
  {"id": "n_put_lock", "type": "http request", "name": "PUT /kontrol/pintu = LOCK", "method": "PUT", "ret": "txt", "paytoqs": "ignore", "url": "https://bootcamp-iot-dteti-2026-ave-default-rtdb.firebaseio.com/kontrol/pintu.json", "tls": "", "persist": false, "proxy": "", "insecureHTTPParser": false, "authType": "", "senderr": false, "headers": [{"keyType": "Content-Type", "keyValue": "Content-Type", "valueType": "other", "valueValue": "application/json"}], "x": 410, "y": 580, "z": "main_flow", "wires": [["n_lock_toast", "n_lock_debug"]]},
  {"id": "n_lock_toast", "type": "ui_toast", "name": "Toast LOCK", "position": "top right", "displayTime": "3", "highlight": "", "sendall": true, "outputs": 0, "ok": "OK", "cancel": "", "raw": false, "topic": "general", "x": 700, "y": 560, "z": "main_flow", "wires": []},
  {"id": "n_lock_debug", "type": "debug", "name": "Debug LOCK", "active": true, "tosidebar": true, "console": false, "tostatus": false, "complete": "true", "targetType": "full", "statusVal": "", "statusType": "auto", "x": 700, "y": 600, "z": "main_flow", "wires": []},

  {"id": "n_audit_inject", "type": "inject", "name": "Poll audit 10s", "props": [{"p": "payload"}], "repeat": "10", "crontab": "", "once": true, "onceDelay": 3, "topic": "", "payload": "", "payloadType": "date", "x": 120, "y": 720, "z": "main_flow", "wires": [["n_audit_http"]]},
  {"id": "n_audit_http", "type": "http request", "name": "GET /logs/pintu.json", "method": "GET", "ret": "obj", "paytoqs": "ignore", "url": "https://bootcamp-iot-dteti-2026-ave-default-rtdb.firebaseio.com/logs/pintu.json", "tls": "", "persist": false, "proxy": "", "insecureHTTPParser": false, "authType": "", "senderr": false, "headers": [], "x": 360, "y": 720, "z": "main_flow", "wires": [["n_audit_fmt"]]},
  {"id": "n_audit_fmt", "type": "function", "name": "Object → Array (sorted)", "func": "const obj = msg.payload || {};\nif (typeof obj !== 'object' || obj === null) {\n  msg.payload = [];\n  return msg;\n}\nconst arr = Object.entries(obj).map(([key, v]) => ({\n  key: key,\n  event: (v && v.event) || \"-\",\n  ts: (v && v.ts) || 0,\n  rssi: (v && v.rssi) || 0\n}));\narr.sort((a, b) => b.ts - a.ts);\nmsg.payload = arr.slice(0, 20);\nreturn msg;", "outputs": 1, "noerr": 0, "initialize": "", "finalize": "", "libs": [], "x": 580, "y": 720, "z": "main_flow", "wires": [["n_audit_table", "n_audit_debug"]]},
  {"id": "n_audit_debug", "type": "debug", "name": "Debug Audit", "active": true, "tosidebar": true, "console": false, "tostatus": false, "complete": "payload", "targetType": "msg", "statusVal": "", "statusType": "auto", "x": 840, "y": 680, "z": "main_flow", "wires": []},
  {"id": "n_audit_table", "type": "ui_template", "name": "Audit Table (HTML)", "group": "ui_grp_audit", "order": 1, "width": 0, "height": 0, "format": "<style>\n  .audit-table {\n    width: 100%;\n    border-collapse: collapse;\n    font-size: 13px;\n    font-family: -apple-system,BlinkMacSystemFont,Segoe UI,Roboto,sans-serif;\n  }\n  .audit-table th {\n    background: #0094CE;\n    color: white;\n    padding: 8px 10px;\n    text-align: left;\n    font-weight: 600;\n  }\n  .audit-table td {\n    padding: 7px 10px;\n    border-bottom: 1px solid #eee;\n  }\n  .audit-table tr:nth-child(even) td {\n    background: #f9f9f9;\n  }\n  .event-ADMIN_REMOTE { color: #CA3838; font-weight: 600; }\n  .event-UNLOCKED { color: #008000; font-weight: 600; }\n  .event-LOCKED { color: #555; font-weight: 600; }\n  .empty-msg {\n    padding: 20px;\n    text-align: center;\n    color: #999;\n    font-style: italic;\n  }\n</style>\n\n<div ng-if=\"!msg.payload || msg.payload.length === 0\">\n  <div class=\"empty-msg\">Belum ada audit log. Trigger UNLOCK untuk membuat entry.</div>\n</div>\n\n<table class=\"audit-table\" ng-if=\"msg.payload && msg.payload.length > 0\">\n  <thead>\n    <tr>\n      <th width=\"30%\">Key</th>\n      <th width=\"25%\">Event</th>\n      <th width=\"25%\">TS</th>\n      <th width=\"20%\">RSSI</th>\n    </tr>\n  </thead>\n  <tbody>\n    <tr ng-repeat=\"row in msg.payload\">\n      <td>{{row.key}}</td>\n      <td><span class=\"event-{{row.event}}\">{{row.event}}</span></td>\n      <td>{{row.ts}} dtk</td>\n      <td>{{row.rssi}} dBm</td>\n    </tr>\n  </tbody>\n</table>", "storeOutMessages": true, "fwdInMessages": false, "resendOnRefresh": true, "templateScope": "local", "className": "", "x": 820, "y": 720, "z": "main_flow", "wires": []}
]

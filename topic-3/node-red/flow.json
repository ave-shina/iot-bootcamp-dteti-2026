  {"id": "n_sensor_inject", "type": "inject", "name": "Poll sensor 15s", "props": [{"p": "payload"}], "repeat": "15", "crontab": "", "once": true, "onceDelay": 2, "topic": "", "payload": "", "payloadType": "date", "x": 130, "y": 160, "z": "main_flow", "wires": [["n_sensor_http"]]},
  {"id": "n_sensor_http", "type": "http request", "name": "GET /sensor/01.json", "method": "GET", "ret": "obj", "paytoqs": "ignore", "url": "https://bootcamp-iot-dteti-2026-ave-default-rtdb.firebaseio.com/sensor/01.json", "tls": "", "persist": false, "proxy": "", "insecureHTTPParser": false, "authType": "", "senderr": false, "headers": [], "x": 350, "y": 160, "z": "main_flow", "wires": [["n_sensor_split", "n_sensor_debug"]]},
  {"id": "n_sensor_split", "type": "function", "name": "Split suhu & lembap", "func": "const s = msg.payload;\nif (!s || typeof s !== 'object') return null;\nconst suhuMsg = { topic: \"suhu\", payload: s.suhu };\nconst lembapMsg = { topic: \"lembap\", payload: s.lembap };\nreturn [suhuMsg, lembapMsg];", "outputs": 2, "noerr": 0, "initialize": "", "finalize": "", "libs": [], "x": 380, "y": 200, "z": "main_flow", "wires": [["n_gauge_suhu", "n_chart"], ["n_gauge_lembap", "n_chart"]]},
  {"id": "n_gauge_suhu", "type": "ui_gauge", "name": "Gauge Suhu", "group": "ui_grp_sensor", "order": 1, "gtype": "gage", "title": "Suhu", "label": "°C", "format": "{{value}}", "min": 0, "max": 50, "colors": ["#00b500", "#f7df00", "#ca3838"], "seg1": "", "seg2": "", "x": 690, "y": 160, "z": "main_flow", "wires": []},
  {"id": "n_gauge_lembap", "type": "ui_gauge", "name": "Gauge Lembap", "group": "ui_grp_sensor", "order": 2, "gtype": "gage", "title": "Kelembapan", "label": "%", "format": "{{value}}", "min": 0, "max": 100, "colors": ["#cc5500", "#f7df00", "#00b500"], "seg1": "", "seg2": "", "x": 690, "y": 200, "z": "main_flow", "wires": []},
  {"id": "n_chart", "type": "ui_chart", "name": "Chart Sensor", "group": "ui_grp_sensor", "order": 3, "tab": "", "chartType": "line", "legend": "true", "xlog": "false", "ylog": "false", "points": "false", "interpolate": "linear", "nodata": "Tunggu data sensor...", "width": "6", "height": "4", "x": 690, "y": 240, "z": "main_flow", "wires": [[]]},
  {"id": "n_sensor_debug", "type": "debug", "name": "Debug Sensor (raw)", "active": true, "tosidebar": true, "console": false, "tostatus": false, "complete": "payload", "targetType": "msg", "statusVal": "", "statusType": "auto", "x": 620, "y": 100, "z": "main_flow", "wires": []},


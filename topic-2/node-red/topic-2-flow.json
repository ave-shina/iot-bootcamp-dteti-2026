    {
        "id": "format_audit",
        "type": "function",
        "z": "f1",
        "name": "Format audit dengan timestamp",
        "func": "// Tambahkan timestamp ke payload audit\nconst now = new Date();\nconst ts = now.toLocaleTimeString('id-ID');\n\n// Emoji berdasarkan event\nlet emoji = '📋';\nconst e = msg.payload;\nif (e === 'UNLOCKED')    emoji = '🔓';\nelse if (e === 'LOCKED')      emoji = '🔒';\nelse if (e === 'ADMIN_REMOTE')emoji = '👑';\nelse if (e === 'online')      emoji = '🟢';\nelse if (e === 'offline')     emoji = '🔴';\n\nmsg.payload = `${ts}  ${emoji}  ${e}`;\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 450,
        "y": 560,
        "wires": [
            [
                "text_audit",
                "text_status_pintu"
            ]
        ]
    },
